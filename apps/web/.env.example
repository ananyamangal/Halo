# Base URL of the FastAPI backend (the /api/v1 prefix is required).
# In local development the default in src/lib/api/http.ts already covers this,
# so this file is informational — copy it to .env.local to override.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Data source toggle. When "true" (the default) the app runs fully standalone on
# an in-memory mock dataset with NO backend required. Set to "false" to hit the
# live FastAPI backend at NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_MOCK=true
